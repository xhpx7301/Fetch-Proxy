# Only HTTPS subscription hostnames are allowed. Separate multiple hosts with commas.
ALLOWED_HOSTS=sub.example.com

# Generate a high-entropy value, for example: openssl rand -hex 32
RELAY_SECRET=replace-with-a-long-random-secret

# Docker network shared with Nginx Proxy Manager.
DOCKER_NETWORK=fetch-relay-net

# Used only when printing the MiSub Fetch Proxy prefix.
RELAY_DOMAIN=fetch.example.com
